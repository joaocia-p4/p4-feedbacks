# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# CORS — origem(ns) do front-end permitida(s). Use vírgula para várias.
# Em desenvolvimento, "*" libera tudo. Em produção, informe a URL do site.
CORS_ORIGIN=*

# Fuso horário de negócio para calcular "hoje" (status atrasado, filtro de envio).
# Mantém o backend alinhado com as telas mesmo hospedado em servidor UTC.
BUSINESS_TZ=America/Sao_Paulo

# ─── Autenticação ────────────────────────────────────────────────────────────
# TROQUE em produção por uma string longa e aleatória.
JWT_SECRET=troque-este-segredo-por-uma-string-longa-e-aleatoria
JWT_EXPIRES_IN=7d

# ─── Banco de dados ──────────────────────────────────────────────────────────
# Se DATABASE_URL estiver definida, o backend usa PostgreSQL (produção).
# Se NÃO estiver definida, usa SQLite local em ./data/p4.sqlite (zero-config).
# DATABASE_URL=postgres://usuario:senha@host:5432/p4_feedbacks
# DATABASE_SSL=true            # alguns provedores (Render/Heroku) exigem SSL

# Caminho do arquivo SQLite (usado só quando DATABASE_URL não está definida)
SQLITE_FILE=./data/p4.sqlite

# ─── Seed ────────────────────────────────────────────────────────────────────
# Senha aplicada a todos os usuários mock criados pelo seed (apenas dev/demo).
SEED_PASSWORD=metodop4

# ─── Admin inicial (produção / primeiro deploy) ──────────────────────────────
# No PRIMEIRO boot com o banco vazio, o backend cria UM administrador com estes
# dados. Depois você cria os demais usuários pela própria interface. É seguro
# manter definido (não recria se já houver usuários). Em produção, defina estes
# valores nas variáveis de ambiente do Render — não comite a senha real.
ADMIN_NAME=João Pedro
ADMIN_EMAIL=voce@suaempresa.com
ADMIN_PASSWORD=defina-uma-senha-forte
